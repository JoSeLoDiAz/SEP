# ════════════════════════════════════════════════════════════════
#   SEP Local — Variables de Entorno
#   Copia este archivo a:  backend/.env
#   Y reemplaza los valores marcados con ⚠️
#   Guía completa: docs/informes/10-setup-desarrolladores.md
# ════════════════════════════════════════════════════════════════

# ─── Backend ──────────────────────────────────────────────────────
BACKEND_PORT=4000
NODE_ENV=development

# ─── Oracle (apunta al server centralizado vía Cloudflare Tunnel) ─
# Cada dev tiene cloudflared corriendo como servicio Windows que
# mapea sepdb.ggpcsena.com → localhost:1521 (transparente).
ORACLE_USER=SEPLOCAL
ORACLE_PASSWORD=⚠️PEDIRLE_AL_LIDER⚠️
ORACLE_CONNECT_STRING=localhost:1521/XEPDB1

# ─── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=⚠️CAMBIAR_64_CHARS_MINIMO⚠️
JWT_EXPIRES_IN=8h

# ─── SMTP (correo institucional) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=⚠️PEDIRLE_AL_LIDER⚠️
SMTP_PASS=⚠️PEDIRLE_AL_LIDER⚠️

# ─── URL pública ──────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
