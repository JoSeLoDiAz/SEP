# ════════════════════════════════════════════════════════════════
#   SEP Local — Variables de Entorno
#   Copia este archivo a:  backend/.env
#   Y reemplaza los valores marcados con ⚠️
#   Guía completa: docs/informes/10-setup-desarrolladores.md
# ════════════════════════════════════════════════════════════════

# ─── Backend ──────────────────────────────────────────────────────
BACKEND_PORT=4000
NODE_ENV=development

# ─── Oracle (apunta al server centralizado vía Cloudflare Tunnel) ─
# Cada dev tiene cloudflared corriendo como servicio Windows que
# mapea sepdb.ggpcsena.com → localhost:1521 (transparente).
#
# Usuario SEP_APP: tiene INSERT/UPDATE/DELETE/SELECT en todas las
# tablas pero NO puede DROP/ALTER/CREATE. Además un logon trigger
# lo bloquea si intentas usarlo en SQL Developer (solo conecta
# desde Node). Para consultar datos a mano usa SEP_LECTOR.
ORACLE_USER=SEP_APP
ORACLE_PASSWORD=⚠️PEDIRLE_AL_LIDER⚠️
# Conexión:
#   • Dev en PC local (vía cloudflared)   → localhost:1521/XEPDB1
#   • Backend Docker en el server         → host.docker.internal:1521/XEPDB1
ORACLE_CONNECT_STRING=localhost:1521/XEPDB1

# ─── JWT ──────────────────────────────────────────────────────────
# 30m + sliding-session: el backend regenera el token en cada
# request autenticado y lo devuelve por el header X-New-Token.
# El frontend lo guarda automáticamente. Idle real → 20 min
# sin actividad cierra la sesión (IdleLogout).
JWT_SECRET=⚠️CAMBIAR_64_CHARS_MINIMO⚠️
JWT_EXPIRES_IN=30m

# ─── SMTP (correo institucional) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=⚠️PEDIRLE_AL_LIDER⚠️
SMTP_PASS=⚠️PEDIRLE_AL_LIDER⚠️

# ─── URL pública ──────────────────────────────────────────────────
APP_URL=http://localhost:3000

# ─── Cloudflare Turnstile (captcha del login) ─────────────────────
# Pídele la secret key a Josse. Sin ella el backend OMITE la verificación
# de captcha (modo dev). En producción siempre debe estar configurada.
TURNSTILE_SECRET=⚠️PEDIRLE_AL_LIDER⚠️

# ─── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
# Cloudflare Turnstile site key (pública, OK en el repo)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADD6VVCyoP6eM5Ao
